{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "Skill(superpowers:writing-skills)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(sed -i *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(git restore *)",
      "Bash(git clean *)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git rm *)",
      "Bash(git stash drop *)",
      "Bash(git stash clear *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)"
    ]
  }
}
